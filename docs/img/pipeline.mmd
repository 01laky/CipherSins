flowchart TB
	subgraph INPUT["Scan input"]
		direction LR
		PATHS["paths · cwd"]
		GLOBS["include / exclude globs"]
		CONFIG["ciphersins.config.json · optional"]
	end

	subgraph RESOLVE["File resolution · @ciphersins/core"]
		direction TB
		ROOT["resolveDefaultScanRoot()"]
		RF["resolveFiles() · tinyglobby"]
		META["scannedFiles · skippedPaths"]
		ROOT --> RF --> META
	end

	subgraph PARSE["TypeScript compiler API"]
		direction TB
		PSF["parseSourceFile()"]
		SF["SourceFile AST"]
		PSF --> SF
	end

	subgraph RULES["Rule engine"]
		direction TB
		REG["allRules registry"]
		CTX["createRuleContext()"]
		RUN["runRules() · per file"]
		RULE["Rule.run(context) → Finding[]"]
		REG --> RUN
		CTX --> RUN
		RUN --> RULE
	end

	subgraph REPORT["Reporting · @ciphersins/core"]
		direction TB
		SORT["sortFindings()"]
		JSON["formatJson() · schemaVersion 1"]
		SARIF["formatSarif() · SARIF 2.1.0"]
		SORT --> JSON
		SORT --> SARIF
	end

	subgraph OUTPUT["CLI output"]
		direction LR
		FIND["findings · snippet · helpUrl"]
		SUM["summary by severity"]
		PRETTY["pretty · stdout"]
		JOUT["json · stdout / --output"]
		SOUT["sarif · stdout / --output"]
		FAIL["--fail-on · exit 0 / 1 / 2"]
	end

	PATHS --> ROOT
	GLOBS --> RF
	CONFIG --> FAIL
	META --> PSF
	SF --> CTX
	RULE --> FIND
	FIND --> SUM
	SUM --> SORT
	JSON --> JOUT
	SARIF --> SOUT
	SUM --> PRETTY
	SUM --> FAIL

